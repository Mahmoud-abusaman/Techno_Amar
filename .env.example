# Copy to .env.dev for local development:
#   cp .env.example .env.dev
#
# Used by npm scripts via dotenv-cli (e.g. db:migrate:dev, start:dev with NODE_ENV=dev).

# Server
PORT=3000

# PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/techno_amar"

# JWT
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_AUDIENCE="techno-amar-api"
JWT_ACCESS_TOKEN_TTL=900
JWT_REFRESH_TOKEN_TTL=604800
JWT_PASSWORD_RESET_SECRET="change-me-password-reset-secret"
JWT_PASSWORD_RESET_TTL=600

# OTP
OTP_LENGTH=4
OTP_EXPIRE_MINUTES=10

# ImageKit (https://imagekit.io)
IMAGEKIT_PRIVATE_KEY="your-imagekit-private-key"
IMAGEKIT_PUBLIC_KEY="your-imagekit-public-key"
IMAGEKIT_URL_ENDPOINT="https://ik.imagekit.io/your-imagekit-id"
IMAGEKIT_AUTH_EXPIRE_SECONDS=1800
