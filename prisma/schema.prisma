// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ======================
// ENUMS
// ======================

enum UserRole {
  ADMIN
  CITIZEN
  EMPLOYEE
  DEPARTMENT_MANAGER
}

enum GazaCities {
  GAZA
  MIDDLE
  KHAN
  RAFAH
  NORTH
}

enum OtpType {
  password_reset
  phone_verification
}

enum AccountStatus {
  PENDING_VERIFICATION
  ACTIVE
  INACTIVE
  REJECTED
}

enum ServiceStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum DamageSeverity {
  MINOR
  MODERATE
  SEVERE
}

enum DamageAssessmentStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  RESOLVED
}

enum RequestStatus {
  SUBMITTED
  IN_PROGRESS
  APPROVED
  REJECTED
}

enum RequestTaskStatus {
  BACKLOG
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum RequestPaymentStatus {
  NOT_REQUIRED
  PENDING_VERIFICATION
  PAID
  FAILED
}

enum RequestActivityAction {
  SUBMITTED
  TASK_ASSIGNED
  TASK_COMPLETED
  TASK_REJECTED
  REQUEST_APPROVED
  REQUEST_REJECTED
}

enum ComplaintCategory {
  SERVICE_QUALITY
  EMPLOYEE_CONDUCT
  BILLING
  FACILITY
  OTHER
}

enum ComplaintPriority {
  LOW
  MEDIUM
  HIGH
}

enum ComplaintStatus {
  SUBMITTED
  UNDER_REVIEW
  RESOLVED
  CLOSED
}

enum DocumentRequirementType {
  MANDATORY
  OPTIONAL
}

enum RequestDocumentCategory {
  CITIZEN_UPLOADED
  INTERNAL
  RESULT
}

// ======================
// ORGANIZATION
// ======================

model Department {
  id          BigInt   @id @default(autoincrement())
  name        String   @unique
  description String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  sections Section[]
  services Service[]

  @@map("departments")
}

model Section {
  id            BigInt     @id @default(autoincrement())
  department_id BigInt
  department    Department @relation(fields: [department_id], references: [id])
  name          String
  description   String?
  is_active     Boolean    @default(true)
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt

  users         User[]
  service_tasks ServiceTask[]
  request_tasks RequestTask[]

  @@unique([department_id, name])
  @@map("sections")
}

// ======================
// USER
// ======================

model User {
  id BigInt @id @default(autoincrement())

  full_name     String
  email         String
  password_hash String

  national_id String? @unique
  employee_id String? @unique

  phone   String?
  address String?

  city GazaCities

  is_verified Boolean  @default(false)
  role        UserRole

  section_id BigInt?
  section    Section? @relation(fields: [section_id], references: [id])

  account_status AccountStatus @default(ACTIVE)
  is_active      Boolean       @default(true)

  created_at      DateTime        @default(now())
  updated_at      DateTime        @updatedAt
  otpCodes              OtpCode[]
  citizen_profile       CitizenProfile?
  created_services      Service[]
  damage_assessments    DamageAssessment[]
  complaints            Complaint[]
  citizen_requests      ServiceRequest[]  @relation("CitizenRequests")
  assigned_request_tasks RequestTask[]    @relation("AssignedTasks")
  request_activities    RequestActivity[]
  uploaded_documents    RequestDocument[]

  @@map("users")
}

// ======================
// CITIZEN PROFILE
// ======================

model CitizenProfile {
  id            BigInt    @id @default(autoincrement())
  user_id       BigInt    @unique
  user          User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  date_of_birth DateTime?
  verification_document String?
  id_selfie             String?
  rejection_reason      String?
  verified_at           DateTime?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  @@map("citizen_profiles")
}

// ======================
// EMAIL VERIFICATION
// ======================

model OtpCode {
  id BigInt @id @default(autoincrement())

  userId   BigInt
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash String
  type     OtpType
  attempts Int     @default(0)

  expiresAt  DateTime
  consumedAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("otp_codes")
}

// ======================
// SERVICE CATALOG
// ======================

model Service {
  id                        BigInt        @id @default(autoincrement())
  name                      String        @unique
  description               String?
  department_id             BigInt
  department                Department    @relation(fields: [department_id], references: [id])
  fee                       Decimal       @db.Decimal(10, 2)
  estimated_processing_days Int
  status                    ServiceStatus @default(DRAFT)
  created_by                BigInt
  creator                   User          @relation(fields: [created_by], references: [id])
  published_at              DateTime?
  is_active                 Boolean       @default(true)
  created_at                DateTime      @default(now())
  updated_at                DateTime      @updatedAt

  workflow_tasks     ServiceTask[]
  service_requests   ServiceRequest[]
  required_documents RequiredDocument[]

  @@map("services")
}

model ServiceTask {
  id                    BigInt   @id @default(autoincrement())
  service_id            BigInt
  service               Service  @relation(fields: [service_id], references: [id], onDelete: Restrict)
  section_id            BigInt
  section               Section  @relation(fields: [section_id], references: [id])
  name                  String
  description           String?
  task_order            Int
  estimated_time_hours  Int
  is_active             Boolean  @default(true)
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  request_tasks RequestTask[]

  @@unique([service_id, task_order])
  @@map("service_tasks")
}

// ======================
// SERVICE REQUESTS
// ======================

model ServiceRequest {
  id              BigInt               @id @default(autoincrement())
  citizen_id      BigInt
  citizen         User                 @relation("CitizenRequests", fields: [citizen_id], references: [id])
  service_id      BigInt
  service         Service              @relation(fields: [service_id], references: [id])
  status          RequestStatus        @default(SUBMITTED)
  payment_status  RequestPaymentStatus @default(NOT_REQUIRED)
  current_task_id BigInt?
  submitted_at    DateTime             @default(now())
  completed_at    DateTime?
  is_deleted      Boolean              @default(false)
  created_at      DateTime             @default(now())
  updated_at      DateTime             @updatedAt

  tasks      RequestTask[]
  activities RequestActivity[]
  documents  RequestDocument[]

  @@index([citizen_id])
  @@index([service_id])
  @@index([status])
  @@map("service_requests")
}

model RequestTask {
  id                   BigInt            @id @default(autoincrement())
  request_id           BigInt
  request              ServiceRequest    @relation(fields: [request_id], references: [id], onDelete: Cascade)
  service_task_id      BigInt
  service_task         ServiceTask       @relation(fields: [service_task_id], references: [id])
  section_id           BigInt
  section              Section           @relation(fields: [section_id], references: [id])
  name                 String
  task_order           Int
  estimated_time_hours Int
  assigned_employee_id BigInt?
  assigned_employee    User?             @relation("AssignedTasks", fields: [assigned_employee_id], references: [id])
  status               RequestTaskStatus @default(BACKLOG)
  assigned_at          DateTime?
  completed_at         DateTime?
  rejection_reason     String?
  created_at           DateTime          @default(now())
  updated_at           DateTime          @updatedAt

  @@unique([request_id, task_order])
  @@index([section_id, status])
  @@index([assigned_employee_id])
  @@map("request_tasks")
}

model RequestActivity {
  id          BigInt                @id @default(autoincrement())
  request_id  BigInt
  request     ServiceRequest        @relation(fields: [request_id], references: [id], onDelete: Cascade)
  task_id     BigInt?
  actor_id    BigInt
  actor       User                  @relation(fields: [actor_id], references: [id])
  action      RequestActivityAction
  description String?
  created_at  DateTime              @default(now())

  @@index([request_id])
  @@map("request_activities")
}

model RequiredDocument {
  id          BigInt                  @id @default(autoincrement())
  service_id  BigInt
  service     Service                 @relation(fields: [service_id], references: [id], onDelete: Cascade)
  name        String
  description String?
  type        DocumentRequirementType @default(MANDATORY)
  is_active   Boolean                 @default(true)
  created_at  DateTime                @default(now())
  updated_at  DateTime                @updatedAt

  request_documents RequestDocument[]

  @@unique([service_id, name])
  @@map("required_documents")
}

model RequestDocument {
  id                   BigInt                  @id @default(autoincrement())
  request_id           BigInt
  request              ServiceRequest          @relation(fields: [request_id], references: [id], onDelete: Cascade)
  required_document_id BigInt?
  required_document    RequiredDocument?       @relation(fields: [required_document_id], references: [id], onDelete: SetNull)
  task_id              BigInt?
  name                 String
  file_type            String
  file_url             String
  file_id              String
  file_path            String?
  category             RequestDocumentCategory @default(CITIZEN_UPLOADED)
  uploaded_by          BigInt
  uploader             User                    @relation(fields: [uploaded_by], references: [id])
  uploaded_at          DateTime                @default(now())
  created_at           DateTime                @default(now())

  @@index([request_id])
  @@map("request_documents")
}

// ======================
// DAMAGE ASSESSMENT
// ======================

model DamageAssessment {
  id              BigInt                 @id @default(autoincrement())
  citizen_id      BigInt                 @unique
  citizen         User                   @relation(fields: [citizen_id], references: [id], onDelete: Cascade)
  location        String
  description     String
  damage_severity DamageSeverity
  status          DamageAssessmentStatus @default(SUBMITTED)
  submitted_at    DateTime               @default(now())
  created_at      DateTime               @default(now())
  updated_at      DateTime               @updatedAt

  documents DamageAssessmentDocument[]

  @@map("damage_assessments")
}

model DamageAssessmentDocument {
  id            BigInt           @id @default(autoincrement())
  assessment_id BigInt
  assessment    DamageAssessment @relation(fields: [assessment_id], references: [id], onDelete: Cascade)
  name          String
  file_type     String
  file_url      String
  file_id       String
  file_path     String?
  uploaded_at   DateTime         @default(now())
  created_at    DateTime         @default(now())

  @@index([assessment_id])
  @@map("damage_assessment_documents")
}

// ======================
// COMPLAINTS
// ======================

model Complaint {
  id              BigInt            @id @default(autoincrement())
  citizen_id      BigInt
  citizen         User              @relation(fields: [citizen_id], references: [id])
  title           String
  category        ComplaintCategory
  priority        ComplaintPriority @default(MEDIUM)
  location        String?
  description     String
  photo_name      String?
  photo_file_type String?
  photo_url       String?
  photo_file_id   String?
  photo_file_path String?
  status          ComplaintStatus   @default(SUBMITTED)
  submitted_at    DateTime          @default(now())
  created_at      DateTime          @default(now())
  updated_at      DateTime          @updatedAt

  @@index([citizen_id])
  @@index([status])
  @@map("complaints")
}
