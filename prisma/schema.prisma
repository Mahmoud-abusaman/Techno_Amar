// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ======================
// ENUMS
// ======================

enum UserRole {
  ADMIN
  CITIZEN
  EMPLOYEE
  DEPARTMENT_MANAGER
}

enum GazaCities {
  GAZA
  MIDDLE
  KHAN
  RAFAH
  NORTH
}

enum OtpType {
  password_reset
  phone_verification
}

enum AccountStatus {
  PENDING_VERIFICATION
  ACTIVE
  INACTIVE
  REJECTED
}

enum ServiceStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ======================
// ORGANIZATION
// ======================

model Department {
  id          BigInt   @id @default(autoincrement())
  name        String   @unique
  description String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  sections Section[]
  services Service[]

  @@map("departments")
}

model Section {
  id            BigInt     @id @default(autoincrement())
  department_id BigInt
  department    Department @relation(fields: [department_id], references: [id])
  name          String
  description   String?
  is_active     Boolean    @default(true)
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt

  users         User[]
  service_tasks ServiceTask[]

  @@unique([department_id, name])
  @@map("sections")
}

// ======================
// USER
// ======================

model User {
  id BigInt @id @default(autoincrement())

  full_name     String
  email         String
  password_hash String

  national_id String? @unique
  employee_id String? @unique

  phone   String?
  address String?

  city GazaCities

  is_verified Boolean  @default(false)
  role        UserRole

  section_id BigInt?
  section    Section? @relation(fields: [section_id], references: [id])

  account_status AccountStatus @default(ACTIVE)
  is_active      Boolean       @default(true)

  created_at      DateTime        @default(now())
  updated_at      DateTime        @updatedAt
  otpCodes         OtpCode[]
  citizen_profile  CitizenProfile?
  created_services Service[]

  @@map("users")
}

// ======================
// CITIZEN PROFILE
// ======================

model CitizenProfile {
  id            BigInt    @id @default(autoincrement())
  user_id       BigInt    @unique
  user          User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  date_of_birth DateTime?
  // path to the uploaded verification document on disk
  verification_document String?
  rejection_reason      String?
  verified_at           DateTime?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  @@map("citizen_profiles")
}

// ======================
// EMAIL VERIFICATION
// ======================

model OtpCode {
  id BigInt @id @default(autoincrement())

  userId   BigInt
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash String
  type     OtpType
  attempts Int     @default(0)

  expiresAt  DateTime
  consumedAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("otp_codes")
}

// ======================
// SERVICE CATALOG
// ======================

model Service {
  id                        BigInt        @id @default(autoincrement())
  name                      String        @unique
  description               String?
  department_id             BigInt
  department                Department    @relation(fields: [department_id], references: [id])
  fee                       Decimal       @db.Decimal(10, 2)
  estimated_processing_days Int
  status                    ServiceStatus @default(DRAFT)
  created_by                BigInt
  creator                   User          @relation(fields: [created_by], references: [id])
  published_at              DateTime?
  is_active                 Boolean       @default(true)
  created_at                DateTime      @default(now())
  updated_at                DateTime      @updatedAt

  workflow_tasks ServiceTask[]

  @@map("services")
}

model ServiceTask {
  id                    BigInt   @id @default(autoincrement())
  service_id            BigInt
  service               Service  @relation(fields: [service_id], references: [id], onDelete: Restrict)
  section_id            BigInt
  section               Section  @relation(fields: [section_id], references: [id])
  name                  String
  description           String?
  task_order            Int
  estimated_time_hours  Int
  is_active             Boolean  @default(true)
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  @@unique([service_id, task_order])
  @@map("service_tasks")
}
