{
  "name": "techno_amar",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "cross-env NODE_ENV=dev nest start",
    "start:dev": "cross-env NODE_ENV=dev nest start --watch",
    "start:debug": "cross-env NODE_ENV=dev nest start --debug --watch",
    "start:prod": "cross-env NODE_ENV=production node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:migrate:dev": "dotenv -e .env.dev -- prisma migrate dev",
    "db:migrate:prod": "dotenv -e .env -- prisma migrate deploy",
    "db:reset:dev": "dotenv -e .env.dev -- prisma migrate reset",
    "db:reset:prod": "dotenv -e .env -- prisma migrate reset",
    "db:seed:dev": "dotenv -e .env.dev -- prisma db seed",
    "db:push:dev": "dotenv -e .env.dev -- prisma db push",
    "db:studio:dev": "dotenv -e .env.dev -- prisma studio",
    "db:studio:prod": "dotenv -e .env -- prisma studio"
  },
  "dependencies": {
    "@imagekit/nodejs": "^7.8.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "*",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.2.7",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv-cli": "^11.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.7.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "prisma": {
    "seed": "npx tsc --module nodenext --moduleResolution nodenext --esModuleInterop true --target ES2023 --outDir dist-seed prisma/seed.ts && node dist-seed/prisma/seed.js"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "roots": [
      "<rootDir>/src"
    ],
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/src/$1",
      "^generated/(.*)$": "<rootDir>/generated/$1",
      "^@/generated/(.*)$": "<rootDir>/generated/$1",
      "^@/(.*)$": "<rootDir>/src/$1",
      "^@shared/(.*)$": "<rootDir>/src/shared/$1",
      "^@auth/(.*)$": "<rootDir>/src/modules/auth/$1",
      "^@users/(.*)$": "<rootDir>/src/modules/users/$1",
      "^@org/(.*)$": "<rootDir>/src/modules/org/$1",
      "^@citizens/(.*)$": "<rootDir>/src/modules/citizens/$1",
      "^@employees/(.*)$": "<rootDir>/src/modules/employees/$1",
      "^@services/(.*)$": "<rootDir>/src/modules/services/$1",
      "^@service-tasks/(.*)$": "<rootDir>/src/modules/service-tasks/$1",
      "^@damage-assessments/(.*)$": "<rootDir>/src/modules/damage-assessments/$1",
      "^@complaints/(.*)$": "<rootDir>/src/modules/complaints/$1",
      "^@service-requests/(.*)$": "<rootDir>/src/modules/service-requests/$1",
      "^@uploads/(.*)$": "<rootDir>/src/modules/uploads/$1",
      "^@required-documents/(.*)$": "<rootDir>/src/modules/required-documents/$1"
    },
    "collectCoverageFrom": [
      "src/**/*.(t|j)s"
    ],
    "coverageDirectory": "coverage",
    "testEnvironment": "node"
  }
}
